{
  "name": "lvji-ai-trip-planner",
  "version": "0.1.0",
  "description": "AI-assisted travel planning desktop application",
  "author": {
    "name": "drfccv",
    "email": "2713587802@qq.com"
  },
  "desktopName": "lvji",
  "private": true,
  "packageManager": "pnpm@10.10.0",
  "main": "dist/main/index.cjs",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vinext dev --hostname 127.0.0.1 --port 4173",
    "build": "vinext build",
    "start": "vinext start --hostname 127.0.0.1 --port 4173",
    "test": "node --experimental-strip-types --test tests/*.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next --ignore-pattern work --ignore-pattern outputs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "predesktop:dev": "electron-rebuild -f -w better-sqlite3",
    "desktop:dev": "pnpm desktop:build && cross-env DESKTOP_DEV=1 electron .",
    "desktop:build": "tsup && vite build --config vite.renderer.config.ts",
    "predesktop:package": "electron-rebuild -f -w better-sqlite3",
    "desktop:package": "pnpm desktop:build && electron-builder",
    "predesktop:package:win": "electron-rebuild -f -w better-sqlite3",
    "desktop:package:win": "pnpm desktop:build && electron-builder --win nsis portable --x64",
    "predesktop:package:mac": "electron-rebuild -f -w better-sqlite3",
    "desktop:package:mac": "pnpm desktop:build && electron-builder --mac dmg --universal",
    "predesktop:package:linux": "electron-rebuild -f -w better-sqlite3",
    "desktop:package:linux": "pnpm desktop:build && electron-builder --linux AppImage deb --x64",
    "predesktop:test": "pnpm rebuild better-sqlite3",
    "desktop:test": "cross-env TSX_TSCONFIG_PATH=tsconfig.desktop-test.json tsx --test tests/*.desktop-test.mjs"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "drizzle-orm": "0.45.2",
    "lucide-react": "^1.25.0",
    "next": "16.2.6",
    "postgres": "^3.4.7",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@electron/rebuild": "^4.2.0",
    "@tailwindcss/postcss": "4.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "drizzle-kit": "0.31.10",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wait-on": "^9.0.10",
    "wrangler": "4.92.0"
  },
  "type": "module",
  "build": {
    "appId": "com.drfccv.aitripplanner",
    "productName": "旅迹",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "drizzle/*.sql",
      "drizzle/meta/**",
      "desktop/assets/icon.png",
      "desktop/assets/icon.svg",
      "package.json",
      "node_modules/better-sqlite3/**",
      "node_modules/bindings/**",
      "node_modules/file-uri-to-path/**"
    ],
    "win": {
      "icon": "desktop/assets/icon.png",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "portable": {
      "artifactName": "${productName}-${version}-win-${arch}-portable.${ext}"
    },
    "mac": {
      "icon": "desktop/assets/icon.png",
      "category": "public.app-category.travel",
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "icon": "desktop/assets/icon.png",
      "category": "Utility",
      "maintainer": "drfccv <2713587802@qq.com>",
      "syncDesktopName": true,
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "npmRebuild": false
  }
}
